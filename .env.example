# Core
APP_ENV=local
USE_OPENAI=true
USE_ANTHROPIC=false

# OpenAI
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=

# Vector DB
VECTOR_DB_PROVIDER=local
USE_CHROMA=false
CHROMA_PERSIST_DIR=./data/chroma_db

# Pinecone optional
USE_PINECONE=false
PINECONE_API_KEY=
PINECONE_INDEX_NAME=

# Public data optional
DATA_GO_KR_API_KEY=

# Supabase policy DB
POLICY_DATA_SOURCE=local
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_KEY=
SUPABASE_POLICY_TABLE=announcements
SUPABASE_POLICY_DOCUMENT_TABLE=

# Notification
NOTIFICATION_MODE=mock
SOLAPI_API_KEY=
SOLAPI_API_SECRET=
SOLAPI_SENDER=
KAKAO_TEMPLATE_ID=
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=소상공인 금융상담 AI 코파일럿
SMTP_USE_TLS=true
SMTP_USE_SSL=false

# Privacy
MASK_PERSONAL_INFO=true
